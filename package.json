{
  "name": "discord-bot-become-human-2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Discord group-chat AI agent bot with guild-isolated workspaces and Codex-backed agent runs.",
  "bin": {
    "discord-bot-become-human-2": "./dist/index.js"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts --clean --sourcemap",
    "check": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "login:codex": "tsx src/scripts/login-openai-codex.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.74.0",
    "@earendil-works/pi-ai": "^0.74.0",
    "discord.js": "^14.19.3",
    "dotenv": "^17.4.2",
    "langfuse": "^3.38.20",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "yaml": "^2.8.2",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@types/node": "^24.10.2",
    "tsdown": "^0.16.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
